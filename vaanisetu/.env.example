# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID
CDK_DEFAULT_ACCOUNT=YOUR_ACCOUNT_ID
CDK_DEFAULT_REGION=ap-south-1

# API (optional for local dev)
API_URL=http://localhost:3001/api

# Bedrock Agent (optional - workflow path works without these)
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=TSTALIASID
BEDROCK_AGENT_FALLBACK_ALIAS_ID=
BEDROCK_AGENT_ENABLE_TRACE=true
BEDROCK_AGENT_TIMEOUT_MS=55000
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Application security
APPLICATION_CONFIRMATION_SECRET=change-this-to-a-long-random-string-in-production

# Data fallback — set to true so app works even when Aurora is cold
ALLOW_LOCAL_DATA_FALLBACK=true
SESSION_TTL_SECONDS=3600

# Budget mode: normal | guarded | strict
BUDGET_MODE=normal

# Database (populated by CDK / Secrets Manager)
DB_CLUSTER_ARN=
DB_SECRET_ARN=
DB_NAME=vaanisetu

# Documents bucket (populated by write-env-from-cdk.js)
DOCUMENTS_BUCKET=

# SNS (populated by write-env-from-cdk.js)
NOTIFICATION_TOPIC_ARN=

# Local dev
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
